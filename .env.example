# Application
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=8080

# Database
POSTGRES_DB=filevault
POSTGRES_USER=filevault
POSTGRES_PASSWORD=replace-with-local-database-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://filevault:replace-with-local-database-password@localhost:5432/filevault

# Initial administrator
FILEVAULT_ADMIN_EMAIL=admin@example.com
FILEVAULT_ADMIN_PASSWORD=replace-with-a-secure-password
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_HOURS=24

# File storage
FILEVAULT_STORAGE_PATH=./storage
FILEVAULT_DATA_PATH=./storage
MAX_UPLOAD_SIZE_MB=1000
