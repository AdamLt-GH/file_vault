{
  "name": "@file-vault/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The backend API for File Vault.",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "argon2": "0.44.0",
    "express": "5.1.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "22.19.0",
    "prisma": "6.19.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  }
}
